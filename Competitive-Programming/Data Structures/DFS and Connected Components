vector <bool> visited(N,false);
vector<vector<int>> find_connected_component(int n){
    vector<vector<int>> components;
    for(int i=0;i<n;i++){
        if(!visited[i]){
            vector <int> comp;
            dfs(comp,i);
            components.push_back(comp);
        }
    }
    return components;
}
vector <int> dfs(vector <int>& comp, int u){
    visited[u]=true;
    comp.push_back(u);
    for(int v:adjacents[u]){
        if(!visited[v]){
            dfs(comp,v);
        }
    }
}
